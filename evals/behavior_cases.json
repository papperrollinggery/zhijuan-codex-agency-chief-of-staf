  {
    "id": "explicit-write-execute",
    "prompt": "使用 $agency-chief-of-staff。把 README 里的 Repository name 从 agency-model-eval-fixture 改为 agency-model-eval-fixture-v2；先查文件，做最小修改，验证结果并做一次独立 cold review。主线程必须先在前台显示任务已接管，之后才能输出任何进度或执行任务动作。传给 reviewer 的 spawn message 必须逐字等于以下七行，不能追加任何内容：\nAGENCY_WORKER: true\n委派目标：独立复核当前 README.md 是否完成本次最小修改。\n读取范围：README.md；git diff -- README.md；git diff --check。\n写入范围：无。\n期望产物：REVIEW_READBACK、REVIEW_TARGET、REVIEW_VERDICT，均填实际读回值。\n验证要求：直接读取当前 artifact 与相关 diff 后返回实际读回及判定；不得使用主线程提供的值。\n停止条件：返回唯一终态；不启动、不派发。\nreviewer 不得输出 COS_BOOT_RECEIPT 或进度；主线程不得把第一行内容转述给 reviewer。不要创建真实 Codex task/thread。",
    "should_trigger": true,
    "mode": "structured",
    "collaboration": "native_subagents",
    "activation": "explicit",
    "model_smoke": true,
    "sandbox": "workspace-write",
    "must_contain": ["任务已接管"],
    "must_not_contain": ["TOOL_BLOCKED"],
    "require_tool_event": true,
    "require_collab_event": true,
    "expected_file": "README.md",
    "expected_text": "Repository name: agency-model-eval-fixture-v2.",
    "expected_file_content": "# Agency model-eval fixture\n\nRepository name: agency-model-eval-fixture-v2.\n",
    "forbidden_file_texts": ["Repository name: agency-model-eval-fixture."],
    "review_evidence_marker": "# Agency model-eval fixture"
  },
