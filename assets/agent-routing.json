{
  "schema_version": 2,
  "self_skill_names": [
    "agency-chief-of-staff",
    "zhijuan-codex-agency-chief-of-staf"
  ],
  "profiles": {
    "codebase-researcher": {
      "sandbox": "read-only",
      "dispatch_when": ["independent code map", "reproduction path", "dependency evidence"],
      "domain_skill_policy": "explicit-selected-only",
      "compat_execution": "cli-profile-compat"
    },
    "technical-architect": {
      "sandbox": "read-only",
      "dispatch_when": ["cross-module interface", "migration boundary", "architecture risk"],
      "domain_skill_policy": "explicit-selected-only",
      "compat_execution": "cli-profile-compat"
    },
    "developer": {
      "sandbox": "workspace-write",
      "dispatch_when": ["isolated implementation lane", "non-overlapping write scope"],
      "domain_skill_policy": "explicit-selected-only",
      "compat_execution": "main-or-isolated-worktree"
    },
    "reviewer": {
      "sandbox": "read-only",
      "dispatch_when": ["independent cold review"],
      "domain_skill_policy": "explicit-selected-only",
      "compat_execution": "cli-profile-compat"
    },
    "test-debugger": {
      "sandbox": "read-only",
      "dispatch_when": ["failing test", "log diagnosis", "flaky environment classification"],
      "domain_skill_policy": "explicit-selected-only",
      "compat_execution": "cli-profile-compat"
    }
  },
  "execution_modes": {
    "native-custom-agent": {
      "status": "optional-enhancement",
      "requires_named_profile_selection_readback": true
    },
    "cli-profile-compat": {
      "status": "permanent-fallback",
      "runner": "scripts/run_profile_compat.py",
      "supported_sandboxes": ["read-only"],
      "native_role_claim": false,
      "archive_required": true,
      "bounded_timeout": true,
      "sanitized_process_environment": true,
      "tool_shell_path": "/usr/bin:/bin:/usr/sbin:/sbin",
      "git_diff_receipt_profiles": ["codebase-researcher", "reviewer"],
      "structured_tool_result_required": true,
      "cold_context_isolation": "unverified"
    },
    "main-or-isolated-worktree": {
      "status": "write-path",
      "profiles": ["developer"],
      "prompt_only_sandbox_claim": false
    }
  },
  "scenarios": {
    "small-bug": {
      "owner": "main",
      "optional_profiles": ["codebase-researcher", "reviewer"]
    },
    "cross-file-feature": {
      "owner": "main",
      "optional_profiles": ["technical-architect", "developer", "reviewer"]
    },
    "architecture-refactor": {
      "owner": "main",
      "optional_profiles": ["codebase-researcher", "technical-architect", "developer", "reviewer"]
    },
    "test-debug": {
      "owner": "main",
      "optional_profiles": ["test-debugger", "developer", "reviewer"]
    },
    "domain-development": {
      "owner": "main",
      "optional_profiles": ["technical-architect", "developer", "reviewer"],
      "requires_explicit_domain_skill_when_material": true
    },
    "security-release": {
      "owner": "main",
      "optional_profiles": ["codebase-researcher", "reviewer"],
      "requires_fresh_release_evidence": true
    }
  }
}
