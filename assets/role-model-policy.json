{
  "schema_version": 1,
  "policy_name": "agency-role-model-routing",
  "root_ownership": "always",
  "exact_model_resolution": [
    "active-host-catalog",
    "loaded-custom-agent",
    "user-confirmed-exact-id"
  ],
  "model_classes": {
    "efficient": {
      "relative_cost_units": 1,
      "intent": "bounded research, reproduction, and focused diagnostics",
      "default_reasoning": "medium",
      "elevated_reasoning": "high"
    },
    "balanced": {
      "relative_cost_units": 2,
      "intent": "scoped implementation, integration, and multi-cause diagnosis",
      "default_reasoning": "high",
      "elevated_reasoning": "xhigh"
    },
    "judgment": {
      "relative_cost_units": 4,
      "intent": "architecture, independent review, security, and irreversible decisions",
      "default_reasoning": "high",
      "elevated_reasoning": "xhigh"
    }
  },
  "budget_modes": {
    "economy": {
      "max_delegated_roles": 1,
      "max_parallel_roles": 1,
      "max_relative_cost_units": 4,
      "max_auto_upgrades_per_role": 0
    },
    "balanced": {
      "max_delegated_roles": 3,
      "max_parallel_roles": 2,
      "max_relative_cost_units": 8,
      "max_auto_upgrades_per_role": 1
    },
    "quality": {
      "max_delegated_roles": 4,
      "max_parallel_roles": 2,
      "max_relative_cost_units": 16,
      "max_auto_upgrades_per_role": 1
    }
  },
  "profiles": {
    "codebase-researcher": {
      "default_model_class": "efficient",
      "high_risk_model_class": "balanced",
      "budget_priority": 50,
      "independent_required": false
    },
    "technical-architect": {
      "default_model_class": "judgment",
      "high_risk_model_class": "judgment",
      "budget_priority": 80,
      "independent_required": false
    },
    "developer": {
      "default_model_class": "balanced",
      "high_risk_model_class": "judgment",
      "budget_priority": 70,
      "independent_required": false
    },
    "reviewer": {
      "default_model_class": "judgment",
      "high_risk_model_class": "judgment",
      "budget_priority": 100,
      "independent_required": true
    },
    "test-debugger": {
      "default_model_class": "efficient",
      "high_risk_model_class": "balanced",
      "budget_priority": 60,
      "independent_required": false
    }
  },
  "route_contract": {
    "override_fork_turns": "none",
    "same_provider_required_for_direct_model": true,
    "custom_agent_requires_authenticated_provider": true,
    "source_templates_pin_models": false,
    "automatic_global_config_writes": false,
    "truth_states": [
      "planned",
      "planned-unverified",
      "accepted",
      "confirmed",
      "inherited-unverified",
      "unavailable"
    ]
  },
  "external_advisor": {
    "default": "none",
    "mode": "root-facing-read-only",
    "may_edit": false,
    "may_delegate": false,
    "may_approve_final_delivery": false,
    "optional_adapters": [
      "openai-custom-agent",
      "future-host-scoped-adapter"
    ]
  }
}
